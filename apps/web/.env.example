# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key
# Server-side only — NEVER expose in client code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...your-service-role-key

# ─── Shopee Affiliate API (optional fallback — prefer cloud credentials) ──────
SHOPEE_APP_ID=your_app_id_here
SHOPEE_SECRET=your_secret_here

# ─── Discord Webhook (notifications) ─────────────────────────────────────────
# Create: Discord Server → Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── LINE Messaging API (notifications) ──────────────────────────────────────
# Create LINE Official Account → Enable Messaging API → Issue Channel Access Token
# Free tier: 200 push messages/month
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_USER_ID=your-line-user-id

# ─── Vercel Cron Security ────────────────────────────────────────────────────
# Set in Vercel Dashboard → Settings → Environment Variables
# Vercel auto-sends this as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-random-secret-here
